{
  "name": "albina-website",
  "image": "node:26.4.0",
  "remoteUser": "node",
  "containerUser": "node",
  "updateRemoteUserUID": false,
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Vite dev server",
      "onAutoForward": "notify"
    }
  },
  "containerEnv": {
    "NPM_CONFIG_PREFIX": "/home/node/.npm-global",
    "PATH": "/home/node/.npm-global/bin:${containerEnv:PATH}"
  },
  "onCreateCommand": "npm install --global pnpm@11.9.0",
  "postCreateCommand": "pnpm install --frozen-lockfile",
  "customizations": {
    "vscode": {
      "extensions": ["VoidZero.vite-plus-extension-pack"]
    }
  }
}
